# Copy this file to .env for local Docker Compose overrides.

AUTHENTICATION__ADMINEMAIL=admin@pokerbank.local
AUTHENTICATION__ADMINPASSWORD=PokerBank123!

WEBAPP__BASEURL=http://localhost:5173

EMAIL__SMTP__ENABLED=false
EMAIL__SMTP__HOST=smtp.example.com
EMAIL__SMTP__PORT=587
EMAIL__SMTP__USERNAME=
EMAIL__SMTP__PASSWORD=
EMAIL__SMTP__FROMEMAIL=pokerbank@example.com
EMAIL__SMTP__FROMNAME=PokerBank
EMAIL__SMTP__SECURESOCKETOPTIONS=StartTls
